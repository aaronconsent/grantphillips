---
// FeedbackWizard — corner-docked chat widget (no modal/backdrop).
// Submits to Web3Forms; Aaron sets WEB3FORMS_ACCESS_KEY (see README).
const WEB3FORMS_KEY = 'REPLACE_WITH_WEB3FORMS_ACCESS_KEY';
---
<!-- Widget root: launcher + optional nudge + panel -->
<div id="fw-root" class="fw-root" data-state="closed">

  <!-- Proactive nudge bubble (preview that floats above launcher) -->
  <div id="fw-nudge" class="fw-nudge" hidden>
    <button type="button" class="fw-nudge-dismiss" data-nudge-dismiss aria-label="Dismiss">×</button>
    <div class="fw-nudge-avatar">D</div>
    <div class="fw-nudge-body">
      <p class="fw-nudge-from">Dad</p>
      <p class="fw-nudge-msg">Hey Grant — got a minute? I built you a website and need your help making it right. 👋</p>
      <button type="button" class="fw-nudge-cta" data-open>Open chat →</button>
    </div>
  </div>

  <!-- Launcher (closed state) -->
  <button id="fw-launcher" type="button" class="fw-launcher" aria-label="Chat with Dad" data-open>
    <span class="fw-launcher-icon">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
        <path d="M4 4h16c1.1 0 2 .9 2 2v10c0 1.1-.9 2-2 2H7l-3 3V6c0-1.1.9-2 2-2z"/>
      </svg>
    </span>
    <span class="fw-launcher-badge" aria-hidden="true"></span>
  </button>

  <!-- Chat panel (open state) -->
  <section class="fw-panel" id="fw-panel" role="region" aria-labelledby="fw-title" hidden>

    <header class="fw-panel-header">
      <div class="fw-presence">
        <div class="fw-avatar" aria-hidden="true">D</div>
        <div class="fw-presence-text">
          <p id="fw-title" class="fw-title">Dad</p>
          <p id="fw-subtitle" class="fw-subtitle"><span class="fw-online-dot"></span>Online</p>
        </div>
      </div>
      <button type="button" class="fw-minimize" data-close aria-label="Minimize chat">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
    </header>

    <main class="fw-log" id="fw-log" aria-live="polite"></main>

    <footer class="fw-composer" id="fw-composer">
      <div class="fw-attachments" id="fw-attachments"></div>
      <div class="fw-composer-row">
        <button type="button" class="fw-paperclip" id="fw-paperclip" aria-label="Attach files" hidden>
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
        </button>
        <input type="file" id="fw-fileinput" hidden>
        <textarea id="fw-input" class="fw-input" rows="1" placeholder="Type a message…" aria-label="Message"></textarea>
        <button type="button" class="fw-send" id="fw-send" aria-label="Send" disabled>
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
          </svg>
        </button>
      </div>
    </footer>

  </section>
</div>

<style>
  /* ───── Root container ───── */
  .fw-root {
    position: fixed;
    right: 18px;
    bottom: 18px;
    z-index: 60;
    font-family: 'Inter', sans-serif;
  }
  @media (max-width: 480px) {
    .fw-root { right: 14px; bottom: 14px; }
  }
  .fw-root[data-state="open"] .fw-launcher,
  .fw-root[data-state="open"] .fw-nudge { display: none; }

  /* ───── Launcher (closed) ───── */
  .fw-launcher {
    position: relative;
    width: 60px; height: 60px;
    border-radius: 50%;
    background: linear-gradient(135deg, #d4a857, #b88c3a);
    color: #0a0a0a;
    border: none;
    cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    box-shadow: 0 10px 28px rgba(0,0,0,0.45), 0 0 0 1px rgba(212,168,87,0.4);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .fw-launcher:hover { transform: translateY(-2px) scale(1.04); box-shadow: 0 14px 36px rgba(0,0,0,0.55); }
  .fw-launcher-icon { display: inline-flex; }
  .fw-launcher-badge {
    position: absolute; top: 6px; right: 6px;
    width: 12px; height: 12px;
    border-radius: 50%;
    background: #4ade80;
    border: 2px solid #0a0a0a;
    display: none;
  }
  .fw-root[data-resume="1"] .fw-launcher-badge { display: block; }

  /* Subtle pulse to draw the eye when there's saved progress */
  .fw-root[data-resume="1"] .fw-launcher::after {
    content: ''; position: absolute; inset: -4px; border-radius: 50%;
    border: 2px solid rgba(74,222,128,0.5);
    animation: fw-pulse 2.2s ease-out infinite;
  }
  @keyframes fw-pulse {
    0% { transform: scale(1); opacity: 0.7; }
    100% { transform: scale(1.25); opacity: 0; }
  }

  /* ───── Nudge bubble (proactive Dad message above launcher) ───── */
  .fw-nudge {
    position: absolute;
    bottom: 78px; right: 0;
    width: 300px;
    background: #161616;
    border: 1px solid #2a2a2a;
    border-radius: 14px;
    padding: 14px 16px 12px;
    box-shadow: 0 16px 36px rgba(0,0,0,0.5);
    animation: fw-nudge-in 0.35s cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  .fw-nudge[hidden] { display: none; }
  @keyframes fw-nudge-in {
    from { opacity: 0; transform: translateY(8px) scale(0.96); }
    to { opacity: 1; transform: none; }
  }
  .fw-nudge::after {
    content: '';
    position: absolute; right: 22px; bottom: -7px;
    width: 14px; height: 14px;
    background: #161616;
    border-right: 1px solid #2a2a2a;
    border-bottom: 1px solid #2a2a2a;
    transform: rotate(45deg);
  }
  .fw-nudge-dismiss {
    position: absolute; top: 8px; right: 8px;
    background: none; border: none; color: #6a6a6a;
    width: 24px; height: 24px; border-radius: 50%;
    cursor: pointer; font-size: 1.2rem; line-height: 1;
  }
  .fw-nudge-dismiss:hover { background: #2a2a2a; color: #f5efe1; }
  .fw-nudge-avatar {
    display: inline-block;
    width: 28px; height: 28px; border-radius: 50%;
    background: linear-gradient(135deg, #d4a857, #b88c3a); color: #0a0a0a;
    font-family: 'Fraunces', serif; font-size: 0.9rem; font-weight: 600;
    text-align: center; line-height: 28px;
    margin-bottom: 6px;
  }
  .fw-nudge-from {
    margin: 0; font-size: 0.65rem; color: #d4a857;
    letter-spacing: 0.2em; text-transform: uppercase; font-weight: 600;
  }
  .fw-nudge-msg {
    margin: 6px 0 12px; color: #ece5d2; font-size: 0.92rem; line-height: 1.45;
  }
  .fw-nudge-cta {
    background: #d4a857; color: #0a0a0a;
    border: none; border-radius: 999px;
    padding: 8px 16px; font-size: 0.82rem; font-weight: 600;
    cursor: pointer; font-family: inherit;
    transition: background 0.15s;
  }
  .fw-nudge-cta:hover { background: #e6b966; }

  /* ───── Chat panel (open) ───── */
  .fw-panel {
    width: 380px;
    height: min(620px, calc(100dvh - 36px));
    background: #0d0d0d;
    border: 1px solid #2a2a2a;
    border-radius: 16px;
    overflow: hidden;
    display: flex; flex-direction: column;
    box-shadow: 0 30px 80px rgba(0,0,0,0.7), 0 0 0 1px rgba(212,168,87,0.1);
    animation: fw-panel-in 0.25s cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  .fw-panel[hidden] { display: none; }
  @keyframes fw-panel-in {
    from { opacity: 0; transform: translateY(12px) scale(0.97); }
    to { opacity: 1; transform: none; }
  }
  /* On mobile, panel fills the screen */
  @media (max-width: 640px) {
    .fw-root[data-state="open"] {
      inset: 0; right: 0; bottom: 0;
      width: 100vw; height: 100dvh;
    }
    .fw-panel {
      width: 100vw; height: 100dvh;
      border-radius: 0; border: none;
      max-height: none;
    }
  }

  /* ───── Panel header ───── */
  .fw-panel-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 14px;
    background: #131313;
    border-bottom: 1px solid #232323;
    flex-shrink: 0;
  }
  .fw-presence { display: flex; align-items: center; gap: 12px; }
  .fw-avatar {
    width: 38px; height: 38px; border-radius: 50%;
    background: linear-gradient(135deg, #d4a857, #b88c3a);
    color: #0a0a0a;
    display: inline-flex; align-items: center; justify-content: center;
    font-family: 'Fraunces', serif; font-size: 1.05rem; font-weight: 600;
    box-shadow: 0 2px 8px rgba(212,168,87,0.25);
  }
  .fw-presence-text { line-height: 1.2; }
  .fw-title {
    margin: 0; font-size: 0.95rem; font-weight: 600; color: #f5efe1;
  }
  .fw-subtitle {
    margin: 2px 0 0; font-size: 0.72rem; color: #8a8a8a;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .fw-online-dot {
    display: inline-block; width: 7px; height: 7px;
    border-radius: 50%; background: #4ade80;
    box-shadow: 0 0 0 2px rgba(74,222,128,0.2);
  }
  .fw-minimize {
    background: none; border: none; color: #8a8a8a;
    width: 36px; height: 36px;
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer; border-radius: 50%;
  }
  .fw-minimize:hover { background: #1c1c1c; color: #f5efe1; }

  /* ───── Conversation log ───── */
  .fw-log {
    flex: 1; min-height: 0;
    overflow-y: auto;
    padding: 18px 14px 8px;
    display: flex; flex-direction: column; gap: 8px;
    -webkit-overflow-scrolling: touch;
    background:
      radial-gradient(ellipse 100% 60% at 50% 0%, rgba(212,168,87,0.03), transparent 70%),
      #0d0d0d;
  }
  .fw-row { display: flex; max-width: 100%; }
  .fw-row.dad { justify-content: flex-start; }
  .fw-row.you { justify-content: flex-end; }
  .fw-row.dad + .fw-row.dad { margin-top: -6px; }
  .fw-row.you + .fw-row.you { margin-top: -6px; }
  .fw-row.dad + .fw-row.you, .fw-row.you + .fw-row.dad { margin-top: 8px; }

  .fw-bubble {
    max-width: 84%;
    padding: 10px 14px;
    font-size: 0.94rem;
    line-height: 1.5;
    white-space: pre-wrap;
    word-wrap: break-word;
    animation: fw-pop 0.22s cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  @keyframes fw-pop { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }
  .fw-bubble.dad {
    background: #1d1d1f;
    color: #ece5d2;
    border-radius: 16px 16px 16px 4px;
  }
  .fw-bubble.you {
    background: #d4a857;
    color: #0a0a0a;
    border-radius: 16px 16px 4px 16px;
    font-weight: 500;
  }
  .fw-bubble.you.skip {
    background: transparent;
    color: #6a6a6a;
    border: 1px dashed #2a2a2a;
    font-style: italic;
    font-weight: 400;
    padding: 7px 13px;
  }

  .fw-files { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
  .fw-files img {
    width: 60px; height: 60px; border-radius: 8px;
    object-fit: cover;
    border: 1px solid rgba(0,0,0,0.15);
  }
  .fw-files .doc {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(0,0,0,0.15);
    padding: 6px 10px; border-radius: 6px; font-size: 0.78rem;
  }

  /* Typing indicator */
  .fw-typing {
    align-self: flex-start;
    background: #1d1d1f;
    border-radius: 16px 16px 16px 4px;
    padding: 11px 16px;
    display: inline-flex; gap: 5px;
  }
  .fw-typing .dot {
    width: 6px; height: 6px; border-radius: 50%; background: #6a6a6a;
    animation: fw-blink 1.3s infinite ease-in-out;
  }
  .fw-typing .dot:nth-child(2) { animation-delay: 0.18s; }
  .fw-typing .dot:nth-child(3) { animation-delay: 0.36s; }
  @keyframes fw-blink {
    0%, 80%, 100% { opacity: 0.3; transform: scale(0.85); }
    40% { opacity: 1; transform: scale(1.05); }
  }

  /* Quick-reply chips */
  .fw-chips {
    display: flex; flex-wrap: wrap; gap: 6px;
    padding: 4px 0 4px 2px;
    animation: fw-pop 0.25s ease-out;
  }
  .fw-chip {
    background: rgba(212,168,87,0.18);
    color: #f5deab;
    border: 1.5px solid #d4a857;
    border-radius: 999px;
    padding: 9px 18px;
    font-family: inherit;
    font-size: 0.88rem; font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.1s;
    box-shadow: 0 2px 8px rgba(212,168,87,0.12);
  }
  .fw-chip:hover {
    background: rgba(212,168,87,0.32);
    color: #fff5d6;
    border-color: #e6b966;
    transform: translateY(-1px);
  }
  .fw-chip:active { transform: translateY(0); }
  .fw-chip.primary {
    background: #d4a857;
    color: #0a0a0a;
    border-color: #d4a857;
    font-weight: 700;
    box-shadow: 0 4px 14px rgba(212,168,87,0.35);
  }
  .fw-chip.primary:hover {
    background: #e6b966;
    border-color: #e6b966;
    color: #0a0a0a;
  }

  .fw-saved {
    align-self: center;
    font-size: 0.66rem; color: #4a4a4a;
    letter-spacing: 0.05em;
    padding: 4px 10px;
    opacity: 0; transition: opacity 0.3s;
  }
  .fw-saved.show { opacity: 1; }

  /* ───── Composer ───── */
  .fw-composer {
    border-top: 1px solid #232323;
    padding: 10px 12px;
    padding-bottom: calc(10px + env(safe-area-inset-bottom));
    background: #131313;
    flex-shrink: 0;
  }
  .fw-attachments {
    display: flex; flex-wrap: wrap; gap: 6px;
    margin-bottom: 8px;
  }
  .fw-attachments:empty { display: none; }
  .fw-att-chip {
    display: inline-flex; align-items: center; gap: 6px;
    background: #1d1d1f; border: 1px solid #2a2a2a;
    padding: 4px 6px 4px 8px;
    border-radius: 999px;
    font-size: 0.75rem; color: #ece5d2;
  }
  .fw-att-chip img {
    width: 24px; height: 24px; border-radius: 50%;
    object-fit: cover;
  }
  .fw-att-chip .icon {
    width: 24px; height: 24px; border-radius: 50%;
    background: #2a2a2a; color: #d4a857;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 0.8rem;
  }
  .fw-att-chip button {
    background: none; border: none; color: #8a8a8a;
    cursor: pointer; font-size: 0.95rem; padding: 0 3px; line-height: 1;
  }
  .fw-att-chip button:hover { color: #ff8a8a; }

  .fw-composer-row {
    display: flex; align-items: flex-end; gap: 6px;
  }
  .fw-paperclip, .fw-send {
    flex-shrink: 0;
    width: 38px; height: 38px;
    border-radius: 50%;
    border: none; cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    transition: background 0.15s, color 0.15s;
  }
  .fw-paperclip { background: transparent; color: #8a8a8a; }
  .fw-paperclip:hover { background: #1d1d1f; color: #d4a857; }
  .fw-paperclip.glow {
    color: #d4a857; background: rgba(212,168,87,0.1);
    animation: fw-glow 2s ease-in-out infinite;
  }
  @keyframes fw-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(212,168,87,0); }
    50% { box-shadow: 0 0 0 5px rgba(212,168,87,0.12); }
  }
  .fw-paperclip[hidden] { display: none; }

  .fw-input {
    flex: 1;
    background: #1d1d1f;
    color: #f5efe1;
    border: 1px solid #2a2a2a;
    border-radius: 20px;
    padding: 9px 14px;
    font-family: inherit;
    font-size: 16px; /* prevent iOS zoom */
    line-height: 1.45;
    resize: none;
    -webkit-appearance: none;
    max-height: 140px;
    overflow-y: auto;
    transition: border-color 0.15s;
  }
  .fw-input:focus { border-color: #d4a857; outline: none; }
  .fw-input::placeholder { color: #6a6a6a; }

  .fw-send {
    background: #2a2a2a;
    color: #6a6a6a;
  }
  .fw-send:not(:disabled) { background: #d4a857; color: #0a0a0a; }
  .fw-send:not(:disabled):hover { background: #e6b966; }
  .fw-send:disabled { cursor: not-allowed; }

  /* Avoid scroll lock on desktop; only lock body when full-screen mobile panel is open */
  @media (max-width: 640px) {
    body.fw-open { overflow: hidden; }
  }
</style>

<script is:inline define:vars={{ WEB3FORMS_KEY }}>
(function() {
  const STORAGE_KEY = 'gpb_feedback_v1';
  const NUDGE_SHOWN_KEY = 'gpb_feedback_nudge_v1';

  const STEPS = [
    {
      id: 'intro', kind: 'intro',
      messages: [
        "Hey Grant — Dad here. 👋",
        "I built you a website to help line up more gigs around Lansing, Ann Arbor, and beyond.",
        "Help me get it right? Five to ten minutes is plenty. Your progress saves automatically — come and go as you need."
      ],
      chips: [{ label: "Let's go", primary: true, action: 'next' }]
    },
    {
      id: 'errors', kind: 'ask',
      messages: [
        "First — anything I got wrong?",
        "Wrong year, misspelled name, a teacher I mixed up. Whatever made you wince."
      ],
      placeholder: "Type what's wrong…",
      chips: [{ label: "Nothing wrong", action: 'skip' }]
    },
    {
      id: 'lansing_gigs', kind: 'ask',
      messages: [
        "Real paid gigs you've played in or around Lansing?",
        "Venue, rough date, what you played. Approximate is fine."
      ],
      placeholder: "e.g., Wedding at Eagle Eye, Sept 2025, jazz duo",
      chips: [{ label: "Skip for now", action: 'skip' }]
    },
    {
      id: 'ann_arbor_gigs', kind: 'ask',
      messages: [
        "Paid gigs in or around Ann Arbor?",
        "Same format — venue, date, what you played."
      ],
      placeholder: "e.g., Pit bass for U-M Musical Theatre, Sweeney Todd",
      chips: [{ label: "Skip", action: 'skip' }]
    },
    {
      id: 'other_gigs', kind: 'ask',
      messages: [
        "Other paid gigs anywhere else?",
        "Churches, weddings, jazz dates, sessions, festivals — anything I should list."
      ],
      placeholder: "Venue, city, what you played…",
      chips: [{ label: "Skip", action: 'skip' }]
    },
    {
      id: 'recital_dates', kind: 'ask',
      messages: [
        "Recitals and major school performances?",
        "Senior recital, juries, honors recitals, concerto competitions — dates if you remember."
      ],
      placeholder: "e.g., Junior recital, U-M SMTD, April 2022",
      chips: [{ label: "Skip", action: 'skip' }]
    },
    {
      id: 'photos', kind: 'ask',
      messages: [
        "Got photos of you playing?",
        "Tap the 📎 to add from your camera roll. You can add a comment too."
      ],
      placeholder: "Optional note about the photos…",
      accept: 'image/*', multiple: true, capture: 'environment',
      chips: [{ label: "Don't have any", action: 'skip' }]
    },
    {
      id: 'programs', kind: 'ask',
      messages: [
        "Concert or recital programs?",
        "A phone photo of the cover is perfect. Tap the 📎 to attach."
      ],
      placeholder: "Optional note…",
      accept: 'image/*,application/pdf', multiple: true,
      chips: [{ label: "Skip", action: 'skip' }]
    },
    {
      id: 'bio', kind: 'ask',
      messages: [
        "Anything I should change in the bio?",
        "Add, remove, soften, sharpen — your call. This is your story."
      ],
      placeholder: "Tell me what would make it more you…",
      chips: [{ label: "Bio is fine", action: 'skip' }]
    },
    {
      id: 'repertoire', kind: 'ask',
      messages: [
        "Repertoire to mention?",
        "Specific pieces, jazz standards you call, ensembles you play with regularly."
      ],
      placeholder: "Type what comes to mind…",
      chips: [{ label: "Skip", action: 'skip' }]
    },
    {
      id: 'missing', kind: 'ask',
      messages: [
        "Anything else missing or off?",
        "Services, recordings, social media, websites I should link to."
      ],
      placeholder: "Whatever's on your mind…",
      chips: [{ label: "Nothing else", action: 'skip' }]
    },
    {
      id: 'contact', kind: 'ask',
      messages: [
        "Best way to reach you about updates?",
        "Phone, email — whatever you actually check. Optional."
      ],
      placeholder: "Phone or email",
      singleLine: true,
      chips: [{ label: "You know how to find me", action: 'skip' }]
    },
    {
      id: 'submit', kind: 'submit',
      messages: [
        "That's everything.",
        "Hit Send and it all comes to me. I'll have the site updated in a day or two."
      ],
      chips: [{ label: "Send to Dad →", primary: true, action: 'submit' }]
    }
  ];

  const state = {
    step: 0,
    answers: {},
    files: {},
    initialized: false,
    submitted: false,
    sending: false
  };

  const $ = (id) => document.getElementById(id);
  const root = $('fw-root');
  const launcher = $('fw-launcher');
  const nudge = $('fw-nudge');
  const panel = $('fw-panel');
  const log = $('fw-log');
  const input = $('fw-input');
  const sendBtn = $('fw-send');
  const paperclip = $('fw-paperclip');
  const fileInput = $('fw-fileinput');
  const attachments = $('fw-attachments');
  const composer = $('fw-composer');
  const subtitle = $('fw-subtitle');

  const sleep = (ms) => new Promise(r => setTimeout(r, ms));

  // ───── Persistence ─────
  function saveState() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({
        step: state.step,
        answers: state.answers,
        submitted: state.submitted,
        updatedAt: Date.now()
      }));
      flashSaved();
    } catch (e) {}
    updateLauncherBadge();
  }
  function loadSaved() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null'); }
    catch (e) { return null; }
  }
  function flashSaved() {
    const old = log.querySelector('.fw-saved');
    if (old) old.remove();
    const el = document.createElement('div');
    el.className = 'fw-saved';
    el.textContent = '✓ Saved';
    log.appendChild(el);
    requestAnimationFrame(() => el.classList.add('show'));
    setTimeout(() => el.remove(), 1400);
  }

  function updateLauncherBadge() {
    const saved = loadSaved();
    if (saved && !saved.submitted && saved.step > 0) {
      root.setAttribute('data-resume', '1');
    } else {
      root.removeAttribute('data-resume');
    }
  }

  // ───── Open/close ─────
  function openChat() {
    hideNudge();
    panel.hidden = false;
    root.setAttribute('data-state', 'open');
    if (window.matchMedia('(max-width: 640px)').matches) {
      document.body.classList.add('fw-open');
    }
    if (!state.initialized) initialize();
  }
  function closeChat() {
    panel.hidden = true;
    root.setAttribute('data-state', 'closed');
    document.body.classList.remove('fw-open');
    updateLauncherBadge();
  }
  document.querySelectorAll('[data-open]').forEach(el => el.addEventListener('click', openChat));
  document.querySelectorAll('[data-close]').forEach(el => el.addEventListener('click', closeChat));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && root.getAttribute('data-state') === 'open') closeChat(); });

  // ───── Proactive nudge ─────
  function showNudge() {
    if (sessionStorage.getItem(NUDGE_SHOWN_KEY)) return;
    if (root.getAttribute('data-state') === 'open') return;
    const saved = loadSaved();
    if (saved && saved.submitted) return; // already sent
    if (saved && saved.step > 0) {
      // Mid-conversation — change nudge copy
      const msg = nudge.querySelector('.fw-nudge-msg');
      if (msg) msg.textContent = "Picking up where we left off? Tap here when you're ready.";
    }
    nudge.hidden = false;
    sessionStorage.setItem(NUDGE_SHOWN_KEY, '1');
    // Auto-hide after a while
    setTimeout(hideNudge, 18000);
  }
  function hideNudge() { nudge.hidden = true; }
  document.querySelectorAll('[data-nudge-dismiss]').forEach(el => el.addEventListener('click', (e) => { e.stopPropagation(); hideNudge(); }));

  // ───── Conversation rendering ─────
  function renderDadBubble(text) {
    const row = document.createElement('div');
    row.className = 'fw-row dad';
    const b = document.createElement('div');
    b.className = 'fw-bubble dad';
    b.textContent = text;
    row.appendChild(b);
    log.appendChild(row);
    scrollLog();
  }
  function renderYouBubble(text, opts = {}) {
    const row = document.createElement('div');
    row.className = 'fw-row you';
    const b = document.createElement('div');
    b.className = 'fw-bubble you' + (opts.skip ? ' skip' : '');
    if (text) b.textContent = text;
    if (opts.files && opts.files.length) {
      const wrap = document.createElement('div');
      wrap.className = 'fw-files';
      opts.files.forEach(f => {
        if (f.type && f.type.startsWith('image/')) {
          const img = document.createElement('img');
          const url = URL.createObjectURL(f);
          img.src = url;
          img.alt = f.name;
          img.onload = () => URL.revokeObjectURL(url);
          wrap.appendChild(img);
        } else {
          const d = document.createElement('span');
          d.className = 'doc';
          d.textContent = '📄 ' + f.name;
          wrap.appendChild(d);
        }
      });
      b.appendChild(wrap);
    }
    row.appendChild(b);
    log.appendChild(row);
    scrollLog();
  }
  function showTyping() {
    const row = document.createElement('div');
    row.className = 'fw-row dad';
    const t = document.createElement('div');
    t.className = 'fw-typing';
    t.innerHTML = '<span class="dot"></span><span class="dot"></span><span class="dot"></span>';
    row.appendChild(t);
    log.appendChild(row);
    scrollLog();
    return row;
  }
  function renderChips(chips) {
    if (!chips || !chips.length) return;
    const wrap = document.createElement('div');
    wrap.className = 'fw-chips';
    chips.forEach(c => {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'fw-chip' + (c.primary ? ' primary' : '');
      b.textContent = c.label;
      b.onclick = () => handleChip(c.action);
      wrap.appendChild(b);
    });
    log.appendChild(wrap);
    scrollLog();
  }
  function clearChips() { log.querySelectorAll('.fw-chips').forEach(el => el.remove()); }
  function scrollLog() { requestAnimationFrame(() => { log.scrollTop = log.scrollHeight; }); }

  // ───── Step playback ─────
  async function playStep(skipTyping = false) {
    const s = STEPS[state.step];
    updateSubtitle();
    clearChips();
    const msgs = Array.isArray(s.messages) ? s.messages : [s.messages];
    for (let i = 0; i < msgs.length; i++) {
      if (!skipTyping) {
        const t = showTyping();
        const ms = Math.max(500, Math.min(1500, msgs[i].length * 22));
        await sleep(ms);
        t.remove();
      }
      renderDadBubble(msgs[i]);
      if (i < msgs.length - 1 && !skipTyping) await sleep(220);
    }
    renderChips(s.chips);
    configureComposer(s);
  }

  function updateSubtitle() {
    if (state.submitted) { subtitle.innerHTML = '<span class="fw-online-dot"></span>Online'; return; }
    if (state.step === 0) {
      subtitle.innerHTML = '<span class="fw-online-dot"></span>Online';
    } else if (state.step >= STEPS.length - 1) {
      subtitle.innerHTML = '<span class="fw-online-dot"></span>Wrapping up';
    } else {
      const total = STEPS.length - 2;
      subtitle.innerHTML = '<span class="fw-online-dot"></span>Question ' + state.step + ' of ' + total;
    }
  }

  function configureComposer(s) {
    if (s.kind === 'intro' || s.kind === 'submit') {
      composer.style.display = 'none';
      return;
    }
    composer.style.display = '';
    input.value = '';
    input.placeholder = s.placeholder || 'Type a message…';
    input.disabled = false;
    if (s.singleLine) input.style.maxHeight = '46px';
    else input.style.maxHeight = '';

    if (s.accept) {
      paperclip.hidden = false;
      paperclip.classList.add('glow');
      fileInput.accept = s.accept;
      fileInput.multiple = !!s.multiple;
      if (s.capture) fileInput.setAttribute('capture', s.capture);
      else fileInput.removeAttribute('capture');
    } else {
      paperclip.hidden = true;
      paperclip.classList.remove('glow');
    }
    renderAttachments();
    updateSendState();
    setTimeout(() => input.focus(), 100);
  }

  // ───── Composer behavior ─────
  function autoGrow() {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 140) + 'px';
  }
  function updateSendState() {
    const hasText = input.value.trim().length > 0;
    const s = STEPS[state.step];
    const hasFiles = (state.files[s?.id] || []).length > 0;
    sendBtn.disabled = !(hasText || hasFiles);
  }
  function renderAttachments() {
    attachments.innerHTML = '';
    const s = STEPS[state.step];
    if (!s) return;
    const arr = state.files[s.id] || [];
    arr.forEach((f, i) => {
      const chip = document.createElement('div');
      chip.className = 'fw-att-chip';
      if (f.type && f.type.startsWith('image/')) {
        const img = document.createElement('img');
        const url = URL.createObjectURL(f);
        img.src = url;
        img.onload = () => URL.revokeObjectURL(url);
        chip.appendChild(img);
      } else {
        const ic = document.createElement('span');
        ic.className = 'icon';
        ic.textContent = '📄';
        chip.appendChild(ic);
      }
      const name = document.createElement('span');
      name.textContent = f.name.length > 16 ? f.name.slice(0, 14) + '…' : f.name;
      chip.appendChild(name);
      const rm = document.createElement('button');
      rm.type = 'button';
      rm.textContent = '×';
      rm.onclick = () => { state.files[s.id].splice(i, 1); renderAttachments(); updateSendState(); };
      chip.appendChild(rm);
      attachments.appendChild(chip);
    });
  }

  input.addEventListener('input', () => { autoGrow(); updateSendState(); });
  input.addEventListener('keydown', (e) => {
    const s = STEPS[state.step];
    if (e.key === 'Enter' && !e.shiftKey && (s?.singleLine || (e.metaKey || e.ctrlKey))) {
      e.preventDefault();
      if (!sendBtn.disabled) handleSend();
    }
  });
  paperclip.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', async () => {
    const s = STEPS[state.step];
    if (!s) return;
    state.files[s.id] = state.files[s.id] || [];
    for (const f of Array.from(fileInput.files)) {
      if (f.type.startsWith('image/')) {
        try { state.files[s.id].push(await compressImage(f)); }
        catch (e) { state.files[s.id].push(f); }
      } else {
        state.files[s.id].push(f);
      }
    }
    fileInput.value = '';
    renderAttachments();
    updateSendState();
  });
  sendBtn.addEventListener('click', handleSend);

  function handleSend() {
    const s = STEPS[state.step];
    if (!s || s.kind !== 'ask') return;
    const text = input.value.trim();
    const files = state.files[s.id] || [];
    if (!text && !files.length) return;
    state.answers[s.id] = text || ('[' + files.length + ' file' + (files.length > 1 ? 's' : '') + ']');
    renderYouBubble(text, { files });
    advance();
  }
  function handleChip(action) {
    clearChips();
    const s = STEPS[state.step];
    if (action === 'next') advance();
    else if (action === 'skip') {
      state.answers[s.id] = '__skipped__';
      delete state.files[s.id];
      renderYouBubble('(skipped)', { skip: true });
      advance();
    } else if (action === 'submit') submit();
    else if (action === 'close') closeChat();
  }
  async function advance() {
    state.step++;
    if (state.step >= STEPS.length) state.step = STEPS.length - 1;
    saveState();
    await playStep();
  }

  async function compressImage(file) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onerror = reject;
      reader.onload = (e) => {
        const img = new Image();
        img.onerror = reject;
        img.onload = () => {
          const max = 1600;
          let w = img.width, h = img.height;
          if (w > h && w > max) { h = h * (max / w); w = max; }
          else if (h > max) { w = w * (max / h); h = max; }
          const c = document.createElement('canvas');
          c.width = w; c.height = h;
          c.getContext('2d').drawImage(img, 0, 0, w, h);
          c.toBlob((blob) => {
            const name = file.name.replace(/\.[^/.]+$/, '') + '.jpg';
            resolve(new File([blob], name, { type: 'image/jpeg' }));
          }, 'image/jpeg', 0.82);
        };
        img.src = e.target.result;
      };
      reader.readAsDataURL(file);
    });
  }

  // ───── Resume ─────
  function initialize() {
    state.initialized = true;
    const saved = loadSaved();
    if (saved && !saved.submitted && saved.step > 0) {
      state.step = saved.step;
      state.answers = saved.answers || {};
      rebuildLog();
      const row = document.createElement('div');
      row.className = 'fw-row dad';
      row.innerHTML = '<div class="fw-bubble dad">Welcome back, Grant. Picking up where we left off.</div>';
      log.appendChild(row);
      setTimeout(() => playStep(true), 250);
    } else if (saved && saved.submitted) {
      state.step = 0;
      state.answers = {};
      const row = document.createElement('div');
      row.className = 'fw-row dad';
      row.innerHTML = '<div class="fw-bubble dad">You already sent me a batch — thanks. Got more? We can start a new round.</div>';
      log.appendChild(row);
      setTimeout(() => playStep(true), 250);
    } else {
      playStep();
    }
  }
  function rebuildLog() {
    for (let i = 0; i < state.step; i++) {
      const s = STEPS[i];
      if (!s) continue;
      const msgs = Array.isArray(s.messages) ? s.messages : [s.messages];
      msgs.forEach(m => renderDadBubble(m));
      if (s.kind === 'intro') continue;
      const a = state.answers[s.id];
      if (a === '__skipped__') renderYouBubble('(skipped)', { skip: true });
      else if (a) renderYouBubble(String(a));
    }
  }

  // ───── Submit ─────
  async function submit() {
    if (state.sending) return;
    state.sending = true;
    composer.style.display = 'none';

    const sendingMsg = document.createElement('div');
    sendingMsg.className = 'fw-row dad';
    sendingMsg.innerHTML = '<div class="fw-bubble dad">Sending to me…</div>';
    log.appendChild(sendingMsg);
    scrollLog();

    const fd = new FormData();
    fd.append('access_key', WEB3FORMS_KEY);
    fd.append('subject', '🎻 Grant feedback — ' + new Date().toLocaleString());
    fd.append('from_name', 'Grant (feedback chat)');

    const lines = ['Grant submitted the feedback chat.', '', '─────────────', ''];
    STEPS.forEach(s => {
      if (s.kind === 'intro' || s.kind === 'submit') return;
      const ans = state.answers[s.id];
      const fs = state.files[s.id] || [];
      const qText = Array.isArray(s.messages) ? s.messages.join(' ') : s.messages;
      lines.push('Q: ' + qText);
      if (fs.length) lines.push('A: ' + (ans && ans !== '__skipped__' ? ans + ' (' + fs.length + ' file' + (fs.length > 1 ? 's' : '') + ')' : fs.length + ' file(s) attached'));
      else if (ans === '__skipped__' || !ans) lines.push('A: (skipped)');
      else lines.push('A: ' + ans);
      lines.push('');
    });
    fd.append('message', lines.join('\n'));

    let i = 0;
    Object.entries(state.files).forEach(([qid, arr]) => {
      arr.forEach(f => {
        if (i < 5) { fd.append('attachment[' + i + ']', f, qid + '-' + f.name); i++; }
      });
    });

    try {
      const res = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: fd });
      const j = await res.json();
      if (j.success) {
        state.submitted = true;
        saveState();
        sendingMsg.remove();
        renderDadBubble("Got it. Thanks Grant — I'll update the site in a day or two.");
        renderChips([{ label: "Close chat", primary: true, action: 'close' }]);
      } else {
        state.sending = false;
        sendingMsg.remove();
        renderDadBubble("Couldn't send: " + (j.message || 'unknown error') + ". Your answers are saved here — try again?");
        renderChips([{ label: "Try again", primary: true, action: 'submit' }]);
      }
    } catch (e) {
      state.sending = false;
      sendingMsg.remove();
      renderDadBubble("Couldn't reach the server. Your answers are saved.");
      renderChips([{ label: "Try again", primary: true, action: 'submit' }]);
    }
  }

  // ───── Boot ─────
  updateLauncherBadge();

  // Proactive nudge: shows once per session after a delay
  // Skips if Grant arrived via ?feedback=1 (we auto-open instead)
  if (new URLSearchParams(location.search).get('feedback') === '1') {
    setTimeout(openChat, 400);
  } else {
    setTimeout(showNudge, 7000);
  }
})();
</script>
