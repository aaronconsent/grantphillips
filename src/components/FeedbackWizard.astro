---
// FeedbackWizard — chat-bubble interface for Grant's review.
// Submits to Web3Forms; Aaron sets WEB3FORMS_ACCESS_KEY (see README).
const WEB3FORMS_KEY = 'REPLACE_WITH_WEB3FORMS_ACCESS_KEY';
---
<!-- Floating launcher -->
<button id="fw-launcher" type="button" aria-label="Open chat with Dad" class="fw-launcher hidden">
  <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
    <path d="M4 4h16c1.1 0 2 .9 2 2v10c0 1.1-.9 2-2 2H7l-3 3V6c0-1.1.9-2 2-2z"/>
  </svg>
  <span class="fw-launcher-label">Chat with Dad</span>
  <span class="fw-launcher-dot" aria-hidden="true"></span>
</button>

<!-- Chat modal -->
<div id="fw-modal" class="fw-modal" hidden aria-hidden="true" role="dialog" aria-labelledby="fw-title">
  <div class="fw-backdrop" data-close></div>
  <section class="fw-sheet" role="document">

    <!-- Header (avatar + name + presence + close) -->
    <header class="fw-header">
      <div class="fw-presence">
        <div class="fw-avatar" aria-hidden="true">D</div>
        <div class="fw-presence-text">
          <p id="fw-title" class="fw-title">Dad</p>
          <p id="fw-subtitle" class="fw-subtitle"><span class="fw-online-dot"></span>Online</p>
        </div>
      </div>
      <button type="button" class="fw-close" data-close aria-label="Close chat">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </header>

    <!-- Conversation -->
    <main class="fw-log" id="fw-log" aria-live="polite"></main>

    <!-- Composer (paperclip + auto-grow input + send) -->
    <footer class="fw-composer" id="fw-composer">
      <div class="fw-attachments" id="fw-attachments"></div>
      <div class="fw-composer-row">
        <button type="button" class="fw-paperclip" id="fw-paperclip" aria-label="Attach files" hidden>
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
        </button>
        <input type="file" id="fw-fileinput" hidden>
        <textarea id="fw-input" class="fw-input" rows="1" placeholder="Type a message…" aria-label="Message"></textarea>
        <button type="button" class="fw-send" id="fw-send" aria-label="Send" disabled>
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
          </svg>
        </button>
      </div>
    </footer>

  </section>
</div>

<style>
  /* ───── Launcher ───── */
  .fw-launcher {
    position: fixed; right: 16px; bottom: 16px; z-index: 60;
    display: inline-flex; align-items: center; gap: 10px;
    background: #d4a857; color: #0a0a0a;
    border: none; border-radius: 999px;
    padding: 13px 20px;
    font-family: 'Inter', sans-serif; font-size: 0.88rem; font-weight: 600;
    box-shadow: 0 10px 30px rgba(0,0,0,0.45), 0 0 0 1px rgba(212,168,87,0.45);
    cursor: pointer;
    transition: transform 0.18s, background 0.18s, box-shadow 0.18s;
  }
  .fw-launcher:hover { background: #e6b966; transform: translateY(-2px); }
  .fw-launcher.hidden { display: none; }
  .fw-launcher-dot {
    display: none;
    width: 9px; height: 9px; border-radius: 50%;
    background: #0a0a0a;
  }
  .fw-launcher.resume .fw-launcher-dot { display: block; }
  @media (max-width: 480px) {
    .fw-launcher-label { font-size: 0.82rem; }
  }

  /* ───── Modal shell ───── */
  .fw-modal {
    position: fixed; inset: 0; z-index: 70;
    display: flex; align-items: flex-end; justify-content: center;
  }
  .fw-modal[hidden] { display: none; }
  .fw-backdrop {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.7); backdrop-filter: blur(6px);
    animation: fw-fade 0.2s ease-out;
  }
  @keyframes fw-fade { from { opacity: 0; } to { opacity: 1; } }
  .fw-sheet {
    position: relative;
    width: 100%; max-width: 540px;
    height: 100dvh; max-height: 100dvh;
    background: #0d0d0d;
    display: flex; flex-direction: column;
    animation: fw-rise 0.22s ease-out;
  }
  @keyframes fw-rise { from { transform: translateY(20px); opacity: 0.6; } to { transform: none; opacity: 1; } }
  @media (min-width: 640px) {
    .fw-modal { align-items: center; padding: 24px; }
    .fw-sheet { height: 88dvh; max-height: 760px; border: 1px solid #2a2a2a; border-radius: 16px; overflow: hidden; box-shadow: 0 30px 80px rgba(0,0,0,0.6); }
  }

  /* ───── Header ───── */
  .fw-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 14px;
    background: #131313;
    border-bottom: 1px solid #232323;
    flex-shrink: 0;
  }
  .fw-presence { display: flex; align-items: center; gap: 12px; }
  .fw-avatar {
    width: 40px; height: 40px; border-radius: 50%;
    background: linear-gradient(135deg, #d4a857, #b88c3a);
    color: #0a0a0a;
    display: inline-flex; align-items: center; justify-content: center;
    font-family: 'Fraunces', serif; font-size: 1.1rem; font-weight: 600;
    box-shadow: 0 2px 8px rgba(212,168,87,0.25);
  }
  .fw-presence-text { line-height: 1.2; }
  .fw-title {
    margin: 0; font-family: 'Inter', sans-serif;
    font-size: 0.98rem; font-weight: 600; color: #f5efe1;
  }
  .fw-subtitle {
    margin: 2px 0 0; font-family: 'Inter', sans-serif;
    font-size: 0.74rem; color: #8a8a8a;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .fw-online-dot {
    display: inline-block; width: 7px; height: 7px;
    border-radius: 50%; background: #4ade80;
    box-shadow: 0 0 0 2px rgba(74,222,128,0.2);
  }
  .fw-close {
    background: none; border: none; color: #8a8a8a;
    width: 38px; height: 38px;
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer; border-radius: 50%;
  }
  .fw-close:hover { background: #1c1c1c; color: #f5efe1; }

  /* ───── Conversation log ───── */
  .fw-log {
    flex: 1; min-height: 0;
    overflow-y: auto;
    padding: 20px 16px 8px;
    display: flex; flex-direction: column; gap: 10px;
    -webkit-overflow-scrolling: touch;
    background:
      radial-gradient(ellipse 100% 60% at 50% 0%, rgba(212,168,87,0.03), transparent 70%),
      #0d0d0d;
  }

  .fw-row { display: flex; max-width: 100%; }
  .fw-row.dad { justify-content: flex-start; }
  .fw-row.you { justify-content: flex-end; }
  .fw-row + .fw-row { margin-top: 0; }
  .fw-row.dad + .fw-row.dad { margin-top: -6px; }  /* same-side bubbles cluster */
  .fw-row.you + .fw-row.you { margin-top: -6px; }
  .fw-row.dad + .fw-row.you, .fw-row.you + .fw-row.dad { margin-top: 8px; }

  .fw-bubble {
    max-width: 80%;
    padding: 11px 15px;
    font-family: 'Inter', sans-serif;
    font-size: 0.98rem;
    line-height: 1.5;
    white-space: pre-wrap;
    word-wrap: break-word;
    animation: fw-pop 0.22s cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  @keyframes fw-pop { from { opacity: 0; transform: translateY(4px) scale(0.98); } to { opacity: 1; transform: none; } }

  .fw-bubble.dad {
    background: #1d1d1f;
    color: #ece5d2;
    border-radius: 18px 18px 18px 6px;
  }
  .fw-bubble.dad + .fw-bubble.dad,
  .fw-row.dad + .fw-row.dad .fw-bubble.dad {
    border-top-left-radius: 6px;
  }
  .fw-bubble.you {
    background: #d4a857;
    color: #0a0a0a;
    border-radius: 18px 18px 6px 18px;
    font-weight: 500;
  }
  .fw-bubble.you.skip {
    background: transparent;
    color: #6a6a6a;
    border: 1px dashed #2a2a2a;
    font-style: italic;
    font-weight: 400;
    padding: 8px 14px;
  }

  /* Image thumbs inside your bubble */
  .fw-files {
    display: flex; flex-wrap: wrap; gap: 6px;
    margin-top: 8px;
  }
  .fw-files img {
    width: 64px; height: 64px; border-radius: 8px;
    object-fit: cover;
    border: 1px solid rgba(0,0,0,0.15);
  }
  .fw-files .doc {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(0,0,0,0.15);
    padding: 6px 10px; border-radius: 6px;
    font-size: 0.8rem;
  }

  /* Typing indicator (dad) */
  .fw-typing {
    align-self: flex-start;
    background: #1d1d1f;
    border-radius: 18px 18px 18px 6px;
    padding: 12px 16px;
    display: inline-flex; gap: 5px;
    animation: fw-pop 0.22s ease-out;
  }
  .fw-typing .dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #6a6a6a;
    animation: fw-blink 1.3s infinite ease-in-out;
  }
  .fw-typing .dot:nth-child(2) { animation-delay: 0.18s; }
  .fw-typing .dot:nth-child(3) { animation-delay: 0.36s; }
  @keyframes fw-blink {
    0%, 80%, 100% { opacity: 0.3; transform: scale(0.85); }
    40% { opacity: 1; transform: scale(1.05); }
  }

  /* Quick-reply chips (after dad's message) */
  .fw-chips {
    display: flex; flex-wrap: wrap; gap: 6px;
    padding: 4px 0 4px 4px;
    animation: fw-pop 0.25s ease-out;
  }
  .fw-chip {
    background: transparent;
    color: #d4a857;
    border: 1px solid #3a3a3a;
    border-radius: 999px;
    padding: 8px 16px;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem; font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .fw-chip:hover { background: rgba(212,168,87,0.1); border-color: #d4a857; }
  .fw-chip.primary {
    background: #d4a857; color: #0a0a0a; border-color: #d4a857;
    font-weight: 600;
  }
  .fw-chip.primary:hover { background: #e6b966; }

  /* Saved indicator */
  .fw-saved {
    align-self: center;
    font-size: 0.7rem; color: #5a5a5a;
    letter-spacing: 0.05em;
    padding: 4px 10px;
    opacity: 0; transition: opacity 0.3s;
    pointer-events: none;
  }
  .fw-saved.show { opacity: 1; }

  /* ───── Composer ───── */
  .fw-composer {
    border-top: 1px solid #232323;
    padding: 10px 12px;
    padding-bottom: calc(10px + env(safe-area-inset-bottom));
    background: #131313;
    flex-shrink: 0;
  }
  .fw-attachments {
    display: flex; flex-wrap: wrap; gap: 6px;
    margin-bottom: 8px;
  }
  .fw-attachments:empty { display: none; }
  .fw-att-chip {
    display: inline-flex; align-items: center; gap: 8px;
    background: #1d1d1f; border: 1px solid #2a2a2a;
    padding: 6px 8px 6px 10px;
    border-radius: 999px;
    font-size: 0.78rem; color: #ece5d2;
  }
  .fw-att-chip img {
    width: 28px; height: 28px; border-radius: 50%;
    object-fit: cover;
  }
  .fw-att-chip .icon {
    width: 28px; height: 28px; border-radius: 50%;
    background: #2a2a2a; color: #d4a857;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 0.9rem;
  }
  .fw-att-chip button {
    background: none; border: none; color: #8a8a8a;
    cursor: pointer; font-size: 1rem; padding: 0 4px; line-height: 1;
  }
  .fw-att-chip button:hover { color: #ff8a8a; }

  .fw-composer-row {
    display: flex; align-items: flex-end; gap: 8px;
  }
  .fw-paperclip, .fw-send {
    flex-shrink: 0;
    width: 40px; height: 40px;
    border-radius: 50%;
    border: none; cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    transition: background 0.15s, color 0.15s, opacity 0.15s;
  }
  .fw-paperclip {
    background: transparent;
    color: #8a8a8a;
  }
  .fw-paperclip:hover { background: #1d1d1f; color: #d4a857; }
  .fw-paperclip.glow {
    color: #d4a857;
    background: rgba(212,168,87,0.1);
    animation: fw-glow 2s ease-in-out infinite;
  }
  @keyframes fw-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(212,168,87,0); }
    50% { box-shadow: 0 0 0 6px rgba(212,168,87,0.12); }
  }
  .fw-paperclip[hidden] { display: none; }

  .fw-input {
    flex: 1;
    background: #1d1d1f;
    color: #f5efe1;
    border: 1px solid #2a2a2a;
    border-radius: 22px;
    padding: 10px 16px;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    line-height: 1.45;
    resize: none;
    -webkit-appearance: none;
    max-height: 28dvh;
    overflow-y: auto;
    transition: border-color 0.15s;
  }
  .fw-input:focus { border-color: #d4a857; outline: none; }
  .fw-input::placeholder { color: #6a6a6a; }
  .fw-input:disabled { opacity: 0.5; }

  .fw-send {
    background: #2a2a2a;
    color: #6a6a6a;
  }
  .fw-send:not(:disabled) {
    background: #d4a857;
    color: #0a0a0a;
  }
  .fw-send:not(:disabled):hover { background: #e6b966; }
  .fw-send:disabled { cursor: not-allowed; }

  /* Success/error screens (replace composer area) */
  .fw-screen {
    text-align: center; padding: 24px 18px;
  }
  .fw-screen svg.success { color: #4ade80; margin: 0 auto 12px; display: block; }
  .fw-screen h3 {
    font-family: 'Fraunces', serif; font-size: 1.5rem;
    color: #f5efe1; margin: 0 0 6px; font-weight: 500;
  }
  .fw-screen p {
    color: #b5ad99; font-size: 0.95rem; margin: 0 0 12px; line-height: 1.5;
  }
  .fw-screen .secondary { color: #6a6a6a; font-size: 0.82rem; }

  body.fw-open { overflow: hidden; }
</style>

<script is:inline define:vars={{ WEB3FORMS_KEY }}>
(function() {
  const STORAGE_KEY = 'gpb_feedback_v1';

  const STEPS = [
    {
      id: 'intro', kind: 'intro',
      messages: [
        "Hey Grant — Dad here. 👋",
        "I built you a website to help line up more gigs around Lansing, Ann Arbor, and beyond.",
        "Help me get it right? Five to ten minutes is plenty. Your progress saves automatically — come and go as you need."
      ],
      chips: [{ label: "Let's go", primary: true, action: 'next' }]
    },
    {
      id: 'errors', kind: 'ask',
      messages: [
        "First — anything I got wrong?",
        "Wrong year, misspelled name, a teacher I mixed up. Whatever made you wince."
      ],
      placeholder: "Type what's wrong…",
      chips: [{ label: "Nothing wrong", action: 'skip' }]
    },
    {
      id: 'lansing_gigs', kind: 'ask',
      messages: [
        "Real paid gigs you've played in or around Lansing?",
        "Venue, rough date, what you played. Approximate is fine."
      ],
      placeholder: "e.g., Wedding at Eagle Eye, Sept 2025, jazz duo",
      chips: [{ label: "Skip for now", action: 'skip' }]
    },
    {
      id: 'ann_arbor_gigs', kind: 'ask',
      messages: [
        "Paid gigs in or around Ann Arbor?",
        "Same format — venue, date, what you played."
      ],
      placeholder: "e.g., Pit bass for U-M Musical Theatre, Sweeney Todd",
      chips: [{ label: "Skip", action: 'skip' }]
    },
    {
      id: 'other_gigs', kind: 'ask',
      messages: [
        "Other paid gigs anywhere else?",
        "Churches, weddings, jazz dates, sessions, festivals — anything I should list."
      ],
      placeholder: "Venue, city, what you played…",
      chips: [{ label: "Skip", action: 'skip' }]
    },
    {
      id: 'recital_dates', kind: 'ask',
      messages: [
        "Recitals and major school performances?",
        "Senior recital, juries, honors recitals, concerto competitions — dates if you remember."
      ],
      placeholder: "e.g., Junior recital, U-M SMTD, April 2022",
      chips: [{ label: "Skip", action: 'skip' }]
    },
    {
      id: 'photos', kind: 'ask',
      messages: [
        "Got photos of you playing?",
        "Tap the 📎 to add from your camera roll. You can add a comment too."
      ],
      placeholder: "Optional note about the photos…",
      accept: 'image/*', multiple: true, capture: 'environment',
      chips: [{ label: "Don't have any", action: 'skip' }]
    },
    {
      id: 'programs', kind: 'ask',
      messages: [
        "Concert or recital programs?",
        "A phone photo of the cover is perfect. Tap the 📎 to attach."
      ],
      placeholder: "Optional note…",
      accept: 'image/*,application/pdf', multiple: true,
      chips: [{ label: "Skip", action: 'skip' }]
    },
    {
      id: 'bio', kind: 'ask',
      messages: [
        "Anything I should change in the bio?",
        "Add, remove, soften, sharpen — your call. This is your story."
      ],
      placeholder: "Tell me what would make it more you…",
      chips: [{ label: "Bio is fine", action: 'skip' }]
    },
    {
      id: 'repertoire', kind: 'ask',
      messages: [
        "Repertoire to mention?",
        "Specific pieces you've performed, jazz standards you call, ensembles you play with."
      ],
      placeholder: "Type what comes to mind…",
      chips: [{ label: "Skip", action: 'skip' }]
    },
    {
      id: 'missing', kind: 'ask',
      messages: [
        "Anything else missing or off?",
        "Services, recordings, social media, websites I should link to."
      ],
      placeholder: "Whatever's on your mind…",
      chips: [{ label: "Nothing else", action: 'skip' }]
    },
    {
      id: 'contact', kind: 'ask',
      messages: [
        "Best way to reach you about updates?",
        "Phone, email — whatever you actually check. Optional."
      ],
      placeholder: "Phone or email",
      singleLine: true,
      chips: [{ label: "You know how to find me", action: 'skip' }]
    },
    {
      id: 'submit', kind: 'submit',
      messages: [
        "That's everything.",
        "Hit Send and it all comes to me. I'll have the site updated in a day or two."
      ],
      chips: [{ label: "Send to Dad →", primary: true, action: 'submit' }]
    }
  ];

  const state = {
    step: 0,
    answers: {},
    files: {}, // {qid: [File]} — not persisted
    initialized: false,
    submitted: false,
    sending: false
  };

  const $ = (id) => document.getElementById(id);
  const log = $('fw-log');
  const launcher = $('fw-launcher');
  const modal = $('fw-modal');
  const input = $('fw-input');
  const sendBtn = $('fw-send');
  const paperclip = $('fw-paperclip');
  const fileInput = $('fw-fileinput');
  const attachments = $('fw-attachments');
  const composer = $('fw-composer');
  const subtitle = $('fw-subtitle');

  const sleep = (ms) => new Promise(r => setTimeout(r, ms));

  // ───── Persistence ─────
  function saveState() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({
        step: state.step,
        answers: state.answers,
        submitted: state.submitted,
        updatedAt: Date.now()
      }));
      flashSaved();
    } catch (e) {}
  }
  function loadSaved() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null'); }
    catch (e) { return null; }
  }
  function flashSaved() {
    const old = log.querySelector('.fw-saved');
    if (old) old.remove();
    const el = document.createElement('div');
    el.className = 'fw-saved';
    el.textContent = '✓ Saved';
    log.appendChild(el);
    requestAnimationFrame(() => el.classList.add('show'));
    setTimeout(() => el.remove(), 1400);
  }

  // ───── Launcher state ─────
  function updateLauncher() {
    const saved = loadSaved();
    const label = launcher.querySelector('.fw-launcher-label');
    if (saved && !saved.submitted && saved.step > 0) {
      label.textContent = 'Continue with Dad';
      launcher.classList.add('resume');
    } else if (saved && saved.submitted) {
      label.textContent = 'Send another note';
      launcher.classList.remove('resume');
    } else {
      label.textContent = 'Chat with Dad';
      launcher.classList.remove('resume');
    }
  }

  // ───── Open/close ─────
  function open() {
    modal.hidden = false;
    modal.setAttribute('aria-hidden', 'false');
    document.body.classList.add('fw-open');
    if (!state.initialized) initialize();
  }
  function close() {
    modal.hidden = true;
    modal.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('fw-open');
    updateLauncher();
  }
  launcher.addEventListener('click', open);
  document.querySelectorAll('[data-close]').forEach(el => el.addEventListener('click', close));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !modal.hidden) close(); });

  // ───── Render messages ─────
  function renderDadBubble(text) {
    const row = document.createElement('div');
    row.className = 'fw-row dad';
    const b = document.createElement('div');
    b.className = 'fw-bubble dad';
    b.textContent = text;
    row.appendChild(b);
    log.appendChild(row);
    scrollLog();
  }

  function renderYouBubble(text, opts = {}) {
    const row = document.createElement('div');
    row.className = 'fw-row you';
    const b = document.createElement('div');
    b.className = 'fw-bubble you' + (opts.skip ? ' skip' : '');
    if (text) b.textContent = text;
    if (opts.files && opts.files.length) {
      const wrap = document.createElement('div');
      wrap.className = 'fw-files';
      opts.files.forEach(f => {
        if (f.type && f.type.startsWith('image/')) {
          const img = document.createElement('img');
          const url = URL.createObjectURL(f);
          img.src = url;
          img.alt = f.name;
          img.onload = () => URL.revokeObjectURL(url);
          wrap.appendChild(img);
        } else {
          const d = document.createElement('span');
          d.className = 'doc';
          d.textContent = '📄 ' + f.name;
          wrap.appendChild(d);
        }
      });
      b.appendChild(wrap);
    }
    if (!text && opts.files && opts.files.length) {
      // No text — make it just the files
      b.style.padding = '8px 8px';
    }
    row.appendChild(b);
    log.appendChild(row);
    scrollLog();
  }

  function showTyping() {
    const row = document.createElement('div');
    row.className = 'fw-row dad';
    const t = document.createElement('div');
    t.className = 'fw-typing';
    t.innerHTML = '<span class="dot"></span><span class="dot"></span><span class="dot"></span>';
    row.appendChild(t);
    log.appendChild(row);
    scrollLog();
    return row;
  }

  function renderChips(chips) {
    if (!chips || !chips.length) return null;
    const wrap = document.createElement('div');
    wrap.className = 'fw-chips';
    chips.forEach(c => {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'fw-chip' + (c.primary ? ' primary' : '');
      b.textContent = c.label;
      b.onclick = () => handleChip(c.action);
      wrap.appendChild(b);
    });
    log.appendChild(wrap);
    scrollLog();
    return wrap;
  }

  function clearChips() {
    log.querySelectorAll('.fw-chips').forEach(el => el.remove());
  }

  function scrollLog() {
    requestAnimationFrame(() => { log.scrollTop = log.scrollHeight; });
  }

  // ───── Play step ─────
  async function playStep(skipTyping = false) {
    const s = STEPS[state.step];
    updateSubtitle();
    clearChips();

    const msgs = Array.isArray(s.messages) ? s.messages : [s.messages];
    for (let i = 0; i < msgs.length; i++) {
      if (!skipTyping) {
        const t = showTyping();
        const ms = Math.max(500, Math.min(1500, msgs[i].length * 22));
        await sleep(ms);
        t.remove();
      }
      renderDadBubble(msgs[i]);
      if (i < msgs.length - 1 && !skipTyping) await sleep(220);
    }
    renderChips(s.chips);
    configureComposer(s);
  }

  function updateSubtitle() {
    if (state.submitted) { subtitle.innerHTML = '<span class="fw-online-dot"></span>Online'; return; }
    if (state.step === 0) {
      subtitle.innerHTML = '<span class="fw-online-dot"></span>Online · Welcoming you';
    } else if (state.step >= STEPS.length - 1) {
      subtitle.innerHTML = '<span class="fw-online-dot"></span>Online · Wrapping up';
    } else {
      const total = STEPS.length - 2;
      subtitle.innerHTML = '<span class="fw-online-dot"></span>Question ' + state.step + ' of ' + total;
    }
  }

  function configureComposer(s) {
    if (s.kind === 'intro' || s.kind === 'submit') {
      composer.style.display = 'none';
      return;
    }
    composer.style.display = '';
    input.value = '';
    input.placeholder = s.placeholder || 'Type a message…';
    input.disabled = false;
    if (s.singleLine) {
      input.style.maxHeight = '50px';
    } else {
      input.style.maxHeight = '';
    }
    // Paperclip visibility
    if (s.accept) {
      paperclip.hidden = false;
      paperclip.classList.add('glow');
      fileInput.accept = s.accept;
      fileInput.multiple = !!s.multiple;
      if (s.capture) fileInput.setAttribute('capture', s.capture);
      else fileInput.removeAttribute('capture');
    } else {
      paperclip.hidden = true;
      paperclip.classList.remove('glow');
    }
    renderAttachments();
    updateSendState();
    setTimeout(() => input.focus(), 100);
  }

  // ───── Composer behavior ─────
  function autoGrow() {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 220) + 'px';
  }

  function updateSendState() {
    const hasText = input.value.trim().length > 0;
    const s = STEPS[state.step];
    const hasFiles = (state.files[s?.id] || []).length > 0;
    sendBtn.disabled = !(hasText || hasFiles);
  }

  function renderAttachments() {
    attachments.innerHTML = '';
    const s = STEPS[state.step];
    if (!s) return;
    const arr = state.files[s.id] || [];
    arr.forEach((f, i) => {
      const chip = document.createElement('div');
      chip.className = 'fw-att-chip';
      if (f.type && f.type.startsWith('image/')) {
        const img = document.createElement('img');
        const url = URL.createObjectURL(f);
        img.src = url;
        img.alt = '';
        img.onload = () => URL.revokeObjectURL(url);
        chip.appendChild(img);
      } else {
        const ic = document.createElement('span');
        ic.className = 'icon';
        ic.textContent = '📄';
        chip.appendChild(ic);
      }
      const name = document.createElement('span');
      name.textContent = f.name.length > 18 ? f.name.slice(0, 16) + '…' : f.name;
      chip.appendChild(name);
      const rm = document.createElement('button');
      rm.type = 'button';
      rm.textContent = '×';
      rm.setAttribute('aria-label', 'Remove');
      rm.onclick = () => {
        state.files[s.id].splice(i, 1);
        renderAttachments();
        updateSendState();
      };
      chip.appendChild(rm);
      attachments.appendChild(chip);
    });
  }

  input.addEventListener('input', () => { autoGrow(); updateSendState(); });
  input.addEventListener('keydown', (e) => {
    const s = STEPS[state.step];
    if (e.key === 'Enter' && !e.shiftKey && (s?.singleLine || (e.metaKey || e.ctrlKey))) {
      e.preventDefault();
      if (!sendBtn.disabled) handleSend();
    }
  });

  paperclip.addEventListener('click', () => fileInput.click());

  fileInput.addEventListener('change', async () => {
    const s = STEPS[state.step];
    if (!s) return;
    state.files[s.id] = state.files[s.id] || [];
    for (const f of Array.from(fileInput.files)) {
      if (f.type.startsWith('image/')) {
        try { state.files[s.id].push(await compressImage(f)); }
        catch (e) { state.files[s.id].push(f); }
      } else {
        state.files[s.id].push(f);
      }
    }
    fileInput.value = '';
    renderAttachments();
    updateSendState();
  });

  sendBtn.addEventListener('click', handleSend);

  function handleSend() {
    const s = STEPS[state.step];
    if (!s || s.kind !== 'ask') return;
    const text = input.value.trim();
    const files = state.files[s.id] || [];
    if (!text && !files.length) return;

    state.answers[s.id] = text || ('[' + files.length + ' file' + (files.length > 1 ? 's' : '') + ']');
    renderYouBubble(text, { files });

    advance();
  }

  function handleChip(action) {
    clearChips();
    const s = STEPS[state.step];
    if (action === 'next') {
      advance();
    } else if (action === 'skip') {
      state.answers[s.id] = '__skipped__';
      delete state.files[s.id];
      renderYouBubble('(skipped)', { skip: true });
      advance();
    } else if (action === 'submit') {
      submit();
    } else if (action === 'close') {
      close();
    }
  }

  async function advance() {
    state.step++;
    if (state.step >= STEPS.length) state.step = STEPS.length - 1;
    saveState();
    await playStep();
  }

  async function compressImage(file) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onerror = reject;
      reader.onload = (e) => {
        const img = new Image();
        img.onerror = reject;
        img.onload = () => {
          const max = 1600;
          let w = img.width, h = img.height;
          if (w > h && w > max) { h = h * (max / w); w = max; }
          else if (h > max) { w = w * (max / h); h = max; }
          const c = document.createElement('canvas');
          c.width = w; c.height = h;
          c.getContext('2d').drawImage(img, 0, 0, w, h);
          c.toBlob((blob) => {
            const name = file.name.replace(/\.[^/.]+$/, '') + '.jpg';
            resolve(new File([blob], name, { type: 'image/jpeg' }));
          }, 'image/jpeg', 0.82);
        };
        img.src = e.target.result;
      };
      reader.readAsDataURL(file);
    });
  }

  // ───── Resume on open ─────
  function initialize() {
    state.initialized = true;
    const saved = loadSaved();
    if (saved && !saved.submitted && saved.step > 0) {
      state.step = saved.step;
      state.answers = saved.answers || {};
      rebuildLog();
      const welcome = document.createElement('div');
      welcome.className = 'fw-row dad';
      welcome.innerHTML = '<div class="fw-bubble dad">Welcome back, Grant. Picking up where we left off.</div>';
      log.appendChild(welcome);
      setTimeout(() => playStep(true), 250);
    } else if (saved && saved.submitted) {
      state.step = 0;
      state.answers = {};
      const greet = document.createElement('div');
      greet.className = 'fw-row dad';
      greet.innerHTML = '<div class="fw-bubble dad">You already sent me a batch — thanks. Got more? We can start a new round.</div>';
      log.appendChild(greet);
      setTimeout(() => playStep(true), 250);
    } else {
      playStep();
    }
  }

  function rebuildLog() {
    for (let i = 0; i < state.step; i++) {
      const s = STEPS[i];
      if (!s) continue;
      const msgs = Array.isArray(s.messages) ? s.messages : [s.messages];
      msgs.forEach(m => renderDadBubble(m));
      if (s.kind === 'intro') continue;
      const a = state.answers[s.id];
      if (a === '__skipped__') renderYouBubble('(skipped)', { skip: true });
      else if (a) renderYouBubble(String(a));
    }
  }

  // ───── Submit ─────
  async function submit() {
    if (state.sending) return;
    state.sending = true;
    composer.style.display = 'none';

    // Replace the chips area / show sending state
    const sendingMsg = document.createElement('div');
    sendingMsg.className = 'fw-row dad';
    sendingMsg.innerHTML = '<div class="fw-bubble dad">Sending to me…</div>';
    log.appendChild(sendingMsg);
    scrollLog();

    const fd = new FormData();
    fd.append('access_key', WEB3FORMS_KEY);
    fd.append('subject', '🎻 Grant feedback — ' + new Date().toLocaleString());
    fd.append('from_name', 'Grant (feedback chat)');

    const lines = ['Grant submitted the feedback chat.', '', '─────────────', ''];
    STEPS.forEach(s => {
      if (s.kind === 'intro' || s.kind === 'submit') return;
      const ans = state.answers[s.id];
      const fs = state.files[s.id] || [];
      const qText = Array.isArray(s.messages) ? s.messages.join(' ') : s.messages;
      lines.push('Q: ' + qText);
      if (fs.length) lines.push('A: ' + (ans && ans !== '__skipped__' ? ans + ' (' + fs.length + ' file' + (fs.length > 1 ? 's' : '') + ')' : fs.length + ' file(s) attached'));
      else if (ans === '__skipped__' || !ans) lines.push('A: (skipped)');
      else lines.push('A: ' + ans);
      lines.push('');
    });
    fd.append('message', lines.join('\n'));

    let i = 0;
    Object.entries(state.files).forEach(([qid, arr]) => {
      arr.forEach(f => {
        if (i < 5) { fd.append('attachment[' + i + ']', f, qid + '-' + f.name); i++; }
      });
    });

    try {
      const res = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: fd });
      const j = await res.json();
      if (j.success) {
        state.submitted = true;
        saveState();
        sendingMsg.remove();
        renderDadBubble("Got it. Thanks Grant — I'll update the site in a day or two.");
        renderChips([{ label: "Close chat", primary: true, action: 'close' }]);
      } else {
        state.sending = false;
        sendingMsg.remove();
        renderDadBubble("Couldn't send: " + (j.message || 'unknown error') + ". Your answers are saved here — try again?");
        renderChips([{ label: "Try again", primary: true, action: 'submit' }]);
      }
    } catch (e) {
      state.sending = false;
      sendingMsg.remove();
      renderDadBubble("Couldn't reach the server. Your answers are saved.");
      renderChips([{ label: "Try again", primary: true, action: 'submit' }]);
    }
  }

  // ───── Boot ─────
  updateLauncher();
  setTimeout(() => launcher.classList.remove('hidden'), 600);

  if (new URLSearchParams(location.search).get('feedback') === '1') {
    setTimeout(open, 500);
  }
})();
</script>
