---
const year = new Date().getFullYear();
---
<footer class="border-t border-rule mt-24">
  <div class="container-x py-16">
    <div class="grid md:grid-cols-3 gap-10 lg:gap-16">
      <div>
        <p class="font-display text-2xl text-cream">Grant <span class="text-gold">Phillips</span></p>
        <p class="text-xs uppercase tracking-ultra text-cream/50 mt-2">Double Bass · East Lansing</p>
        <p class="text-sm text-cream/60 mt-5 leading-relaxed">
          Double bassist based in East Lansing, Michigan. Master of Music candidate at the MSU College of Music. Available throughout the lower peninsula.
        </p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-ultra text-cream/50 mb-4">Services</p>
        <ul class="space-y-3 text-sm">
          <li><a href="/services/weddings/" class="text-cream/80 hover:text-gold">Weddings</a></li>
          <li><a href="/services/churches/" class="text-cream/80 hover:text-gold">Churches & sacred</a></li>
          <li><a href="/services/jazz/" class="text-cream/80 hover:text-gold">Jazz clubs</a></li>
          <li><a href="/services/orchestral/" class="text-cream/80 hover:text-gold">Orchestral subbing</a></li>
        </ul>
      </div>
      <div>
        <p class="text-xs uppercase tracking-ultra text-cream/50 mb-4">Coverage</p>
        <ul class="space-y-3 text-sm">
          <li><a href="/areas/east-lansing/" class="text-cream/80 hover:text-gold">East Lansing</a></li>
          <li><a href="/areas/lansing/" class="text-cream/80 hover:text-gold">Lansing</a></li>
          <li><a href="/areas/grand-rapids/" class="text-cream/80 hover:text-gold">Grand Rapids</a></li>
          <li><a href="/areas/ann-arbor/" class="text-cream/80 hover:text-gold">Ann Arbor</a></li>
          <li><a href="/areas/detroit/" class="text-cream/80 hover:text-gold">Detroit metro</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-14 pt-8 border-t border-rule flex flex-col sm:flex-row justify-between gap-4 text-xs text-cream/40">
      <span>© {year} Grant Dewell Phillips. All rights reserved.</span>
      <span>
        <a href="/contact/" class="hover:text-gold">Book a performance</a> ·
        <a href="/faq/" class="hover:text-gold">FAQ</a>
      </span>
    </div>
  </div>
</footer>
