---
interface Props {
  eyebrow: string;
  title: string;
  lede?: string;
  variant?: 'home' | 'page';
  image?: string;
  imageAlt?: string;
  imagePosition?: string; // CSS object-position value
}
const {
  eyebrow,
  title,
  lede,
  variant = 'page',
  image,
  imageAlt = '',
  imagePosition = 'center center',
} = Astro.props;
const isHome = variant === 'home';
const hasImage = !!image;
---
<section class:list={[
  'relative overflow-hidden',
  isHome ? 'pt-24 pb-16 lg:py-28' : 'pt-24 pb-16 lg:py-24'
]}>
  <!-- Atmospheric textured background (always present, no photo overlay) -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 1px 1px, #d4a857 1px, transparent 0); background-size: 32px 32px;"></div>
    {isHome && (
      <>
        <div class="absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full bg-gold/[0.06] blur-3xl"></div>
        <div class="absolute -bottom-40 -left-20 w-[500px] h-[500px] rounded-full bg-gold/[0.04] blur-3xl"></div>
      </>
    )}
  </div>

  <div class="container-x relative">
    {hasImage ? (
      <div class:list={[
        'grid gap-10 lg:gap-16 items-center',
        isHome ? 'lg:grid-cols-[1.1fr_1fr]' : 'lg:grid-cols-[1.2fr_1fr]'
      ]}>
        <!-- Text column -->
        <div>
          <p class="eyebrow mb-6">{eyebrow}</p>
          <h1 class:list={[
            'display text-cream',
            isHome ? 'text-5xl sm:text-6xl lg:text-7xl xl:text-8xl' : 'text-4xl sm:text-5xl lg:text-6xl'
          ]} set:html={title} />
          {lede && (
            <p class="mt-7 max-w-xl text-lg lg:text-xl text-cream/75 leading-relaxed">{lede}</p>
          )}
          <slot />
        </div>

        <!-- Image column -->
        <div class="order-first lg:order-last relative">
          <!-- Gold accent frame -->
          <div class="absolute -inset-2 lg:-inset-3 border border-gold/20 translate-x-2 translate-y-2 lg:translate-x-3 lg:translate-y-3 pointer-events-none"></div>
          <img
            src={image}
            alt={imageAlt}
            class:list={[
              'relative w-full object-cover',
              isHome ? 'aspect-[4/5] lg:aspect-[3/4] max-h-[80vh]' : 'aspect-[4/5] max-h-[60vh]'
            ]}
            style={`object-position: ${imagePosition};`}
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    ) : (
      <div>
        <p class="eyebrow mb-6">{eyebrow}</p>
        <h1 class:list={[
          'display text-cream',
          isHome ? 'text-5xl sm:text-6xl md:text-7xl lg:text-8xl' : 'text-4xl sm:text-5xl lg:text-6xl'
        ]} set:html={title} />
        {lede && (
          <p class="mt-8 max-w-2xl text-lg lg:text-xl text-cream/70 leading-relaxed">{lede}</p>
        )}
        <slot />
      </div>
    )}
  </div>
</section>
