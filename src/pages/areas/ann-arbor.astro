---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
---
<BaseLayout
  title="Double Bassist in Ann Arbor, MI | Grant Phillips"
  description="Hire a Master of Music double bassist for Ann Arbor weddings, U-M area churches, jazz clubs, and Ann Arbor Symphony subbing — bookable from East Lansing."
>
<Hero
  eyebrow="Ann Arbor, Michigan"
  title="For an audience that <span class='italic text-gold'>knows what they're hearing</span>."
  lede="Ann Arbor's musical literacy is unusual — its weddings, services, and jazz dates expect real players. Grant fits the room."
>
  <div class="mt-10"><a href="/contact/" class="btn btn-gold">Book A2 dates</a></div>
</Hero>

<section class="pb-24">
  <div class="container-x max-w-3xl">
    <h2 class="display text-3xl text-gold">Ann Arbor venues &amp; ensembles</h2>
    <ul class="mt-6 space-y-3 text-cream/75 leading-relaxed">
      <li><strong class="text-cream">Concert halls</strong> — Hill Auditorium, Rackham, Michigan Theater, Kerrytown Concert House</li>
      <li><strong class="text-cream">Wedding venues</strong> — Polo Fields, Cobblestone Farm, Kensington Court, Zingerman's Cornman Farms, Ann Arbor City Club</li>
      <li><strong class="text-cream">Churches</strong> — St. Andrew's Episcopal, St. Mary Student Parish, Zion Lutheran, First Presbyterian Ann Arbor, First Congregational</li>
      <li><strong class="text-cream">Jazz rooms</strong> — Kerrytown Concert House, Live at The Earle, Blue LLama Jazz Club</li>
      <li><strong class="text-cream">Orchestras</strong> — Ann Arbor Symphony (subbing), Livingston Symphony, Toledo Symphony</li>
    </ul>
    <h2 class="display text-3xl text-gold mt-16">Services here</h2>
    <ul class="mt-6 space-y-2">
      <li><a href="/services/weddings/" class="text-cream hover:text-gold">Weddings →</a></li>
      <li><a href="/services/churches/" class="text-cream hover:text-gold">Church &amp; sacred music →</a></li>
      <li><a href="/services/jazz/" class="text-cream hover:text-gold">Jazz →</a></li>
      <li><a href="/services/orchestral/" class="text-cream hover:text-gold">Orchestral subbing →</a></li>
    </ul>
  </div>
</section>
</BaseLayout>
