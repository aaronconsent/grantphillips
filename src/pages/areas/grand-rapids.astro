---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
---
<BaseLayout
  title="Double Bassist in Grand Rapids, MI | Grant Phillips"
  description="Hire a conservatory-trained double bassist for Grand Rapids weddings, sacred music, jazz clubs, and Grand Rapids Symphony subbing. Available across West Michigan."
>
<Hero
  eyebrow="Grand Rapids, Michigan"
  title="West Michigan weddings, sacred music, and <span class='italic text-gold'>jazz</span>."
  lede="Grand Rapids' deep wedding and church markets pair perfectly with a Master of Music bassist out of MSU. Routine drive from East Lansing — bookable for ceremonies, services, and supper clubs."
>
  <div class="mt-10"><a href="/contact/" class="btn btn-gold">Check GR dates</a></div>
</Hero>

<section class="pb-24">
  <div class="container-x max-w-3xl">
    <h2 class="display text-3xl text-gold">The Grand Rapids book</h2>
    <ul class="mt-6 space-y-3 text-cream/75 leading-relaxed">
      <li><strong class="text-cream">Wedding venues</strong> — Frederik Meijer Gardens, Cheney Place, Bissell Tree House, Goei Center, Pinnacle Center, Cathedral of St. Andrew</li>
      <li><strong class="text-cream">Churches</strong> — Cathedral of St. Andrew, Mayflower Congregational, Grace Episcopal, LaGrave Avenue CRC, Park Church</li>
      <li><strong class="text-cream">Jazz rooms</strong> — One Trick Pony, SpeakEZ Lounge, hotel lobbies along Monroe</li>
      <li><strong class="text-cream">Orchestras</strong> — Grand Rapids Symphony (subbing), Holland Symphony, Grand Rapids Symphonic Band</li>
      <li><strong class="text-cream">Concert halls</strong> — DeVos Performance Hall, Wealthy Theatre, Royce Auditorium</li>
    </ul>
    <h2 class="display text-3xl text-gold mt-16">Common GR booking shapes</h2>
    <p class="mt-6 text-cream/75 leading-relaxed">Saturday ceremony + cocktail hour at Meijer Gardens and downtown venues; full Easter and Christmas brass-and-strings at the cathedral and large Reformed churches; trio dates at GR jazz rooms.</p>
    <h2 class="display text-3xl text-gold mt-16">Services here</h2>
    <ul class="mt-6 space-y-2">
      <li><a href="/services/weddings/" class="text-cream hover:text-gold">Wedding ceremonies &amp; receptions →</a></li>
      <li><a href="/services/churches/" class="text-cream hover:text-gold">Church &amp; sacred music →</a></li>
      <li><a href="/services/jazz/" class="text-cream hover:text-gold">Jazz →</a></li>
      <li><a href="/services/orchestral/" class="text-cream hover:text-gold">Orchestral subbing →</a></li>
    </ul>
  </div>
</section>
</BaseLayout>
