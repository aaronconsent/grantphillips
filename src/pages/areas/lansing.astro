---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
---
<BaseLayout
  title="Double Bassist in Lansing, MI | Grant Phillips"
  description="Hire a Master of Music double bassist in Lansing, MI for weddings, churches, jazz dates, and Lansing Symphony subbing. Local, no travel fee within the capital region."
>
<Hero
  eyebrow="Lansing, Michigan"
  title="The capital region's <span class='italic text-gold'>double bass</span>."
  lede="From the State Capitol to Old Town to Frandor — Lansing weddings, churches, and jazz rooms can book Grant locally with no travel premium."
>
  <div class="mt-10"><a href="/contact/" class="btn btn-gold">Check Lansing dates</a></div>
</Hero>

<section class="pb-24">
  <div class="container-x max-w-3xl">
    <h2 class="display text-3xl text-gold">Lansing venues &amp; ensembles</h2>
    <ul class="mt-6 space-y-3 text-cream/75 leading-relaxed">
      <li><strong class="text-cream">Concert halls</strong> — Wharton Center, Lansing Center, Old Town's Robin Theatre</li>
      <li><strong class="text-cream">Wedding venues</strong> — English Inn, Eagle Eye Golf Club, Country Club of Lansing, Kellogg Center</li>
      <li><strong class="text-cream">Churches</strong> — Cathedral of St. Mary, First Presbyterian Lansing, Central UMC, St. Paul Episcopal</li>
      <li><strong class="text-cream">Jazz rooms</strong> — Moriarty's Pub, UrbanBeat Event Center, Stober's Bar, downtown hotel lobbies</li>
      <li><strong class="text-cream">Orchestras</strong> — Lansing Symphony Orchestra (subbing), Greater Lansing Symphony Youth</li>
    </ul>
    <h2 class="display text-3xl text-gold mt-16">What Lansing clients book most</h2>
    <p class="mt-6 text-cream/75 leading-relaxed">Wedding ceremonies and cocktail hours at golf clubs and the English Inn, Christmas Eve services at capital-city Catholic and Episcopal parishes, and jazz-trio dates at Old Town events.</p>
    <h2 class="display text-3xl text-gold mt-16">Services here</h2>
    <ul class="mt-6 space-y-2">
      <li><a href="/services/weddings/" class="text-cream hover:text-gold">Weddings →</a></li>
      <li><a href="/services/churches/" class="text-cream hover:text-gold">Churches &amp; sacred music →</a></li>
      <li><a href="/services/jazz/" class="text-cream hover:text-gold">Jazz →</a></li>
      <li><a href="/services/orchestral/" class="text-cream hover:text-gold">Orchestral subbing →</a></li>
    </ul>
  </div>
</section>
</BaseLayout>
