---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---
<BaseLayout
  title="Performance History — Grant Dewell Phillips, Double Bass"
  description="Complete performance history for double bassist Grant Dewell Phillips, from middle school through Master of Music studies at Michigan State University."
>

<Hero
  eyebrow="Performance History"
  title="Every stage, since <span class='italic text-gold'>the beginning</span>."
  lede="A running record of orchestral concerts, recitals, jazz dates, weddings, and sacred services — from the first middle-school program through current graduate work at MSU."
  image="/images/grant-playing.jpg"
  imageAlt="Grant Phillips performing on double bass on stage"
  imagePosition="center 25%"
/>

<section class="pb-24">
  <div class="container-x max-w-4xl">
    <p class="todo">Aaron — send Grant's full gig list and I'll format every entry below. Year, ensemble/venue, location, role.</p>

    <h2 class="display text-3xl lg:text-4xl mt-16 text-gold">2025 — 2026</h2>
    <p class="text-cream/60 mb-2 text-sm tracking-wider uppercase">Graduate years, MSU</p>
    <ul>
      <li class="gig"><span class="gig-year">2026</span><div><p class="gig-title">MSU Symphony Orchestra — Spring Concert</p><p class="gig-venue">Cobb Great Hall, Wharton Center · East Lansing, MI</p></div><p class="gig-role">Section Bass</p></li>
      <li class="gig"><span class="gig-year">2026</span><div><p class="gig-title">Graduate Chamber Recital</p><p class="gig-venue">Murray Hall, MSU College of Music · East Lansing, MI</p></div><p class="gig-role">Bassist</p></li>
      <li class="gig"><span class="gig-year">2025</span><div><p class="gig-title">[Performance title]</p><p class="gig-venue">[Venue · City, ST]</p></div><p class="gig-role">[Role]</p></li>
    </ul>

    <h2 class="display text-3xl lg:text-4xl mt-16 text-gold">2023 — 2024</h2>
    <p class="text-cream/60 mb-2 text-sm tracking-wider uppercase">University of Michigan SMTD — Senior years</p>
    <ul>
      <li class="gig"><span class="gig-year">2023</span><div><p class="gig-title">Solo Double Bass Recital</p><p class="gig-venue">U-M School of Music, Theatre &amp; Dance · Ann Arbor, MI · November 4, 2023</p></div><p class="gig-role">Soloist</p></li>
      <li class="gig"><span class="gig-year">2024</span><div><p class="gig-title">[Symphony program — TBD]</p><p class="gig-venue">[Venue]</p></div><p class="gig-role">Section Bass</p></li>
    </ul>

    <h2 class="display text-3xl lg:text-4xl mt-16 text-gold">2020 — 2022</h2>
    <p class="text-cream/60 mb-2 text-sm tracking-wider uppercase">U-M undergraduate early years</p>
    <ul>
      <li class="gig"><span class="gig-year">2022</span><div><p class="gig-title">[Concerto competition / honors recital]</p><p class="gig-venue">[Venue]</p></div><p class="gig-role">[Role]</p></li>
      <li class="gig"><span class="gig-year">2021</span><div><p class="gig-title">[Summer festival]</p><p class="gig-venue">[Festival · City]</p></div><p class="gig-role">Festival bassist</p></li>
      <li class="gig"><span class="gig-year">2020</span><div><p class="gig-title">[First university orchestra concert]</p><p class="gig-venue">[Venue]</p></div><p class="gig-role">Section Bass</p></li>
    </ul>

    <h2 class="display text-3xl lg:text-4xl mt-16 text-gold">2016 — 2019</h2>
    <p class="text-cream/60 mb-2 text-sm tracking-wider uppercase">Kinder HSPVA — Houston, TX</p>
    <ul>
      <li class="gig"><span class="gig-year">2019</span><div><p class="gig-title">TMEA All-State Symphony Orchestra</p><p class="gig-venue">Texas Music Educators Association Clinic/Convention · San Antonio, TX · February 2019</p></div><p class="gig-role">String Bass</p></li>
      <li class="gig"><span class="gig-year">2018</span><div><p class="gig-title">TMEA All-State Symphonic Band</p><p class="gig-venue">Texas Music Educators Association Clinic/Convention · San Antonio, TX · February 2018</p></div><p class="gig-role">String Bass</p></li>
      <li class="gig"><span class="gig-year">2017</span><div><p class="gig-title">[High school musical pit]</p><p class="gig-venue">[School]</p></div><p class="gig-role">Pit Bassist</p></li>
      <li class="gig"><span class="gig-year">2016</span><div><p class="gig-title">[First high school concert]</p><p class="gig-venue">[School]</p></div><p class="gig-role">Section Bass</p></li>
    </ul>

    <h2 class="display text-3xl lg:text-4xl mt-16 text-gold">2013 — 2015</h2>
    <p class="text-cream/60 mb-2 text-sm tracking-wider uppercase">Middle school — Houston, TX</p>
    <ul>
      <li class="gig"><span class="gig-year">2015</span><div><p class="gig-title">8th-grade Spring Concert</p><p class="gig-venue">[Middle school]</p></div><p class="gig-role">Bassist</p></li>
      <li class="gig"><span class="gig-year">2014</span><div><p class="gig-title">[First public performance]</p><p class="gig-venue">[Venue]</p></div><p class="gig-role">Section Bass</p></li>
      <li class="gig"><span class="gig-year">2013</span><div><p class="gig-title">First orchestra concert</p><p class="gig-venue">[Middle school]</p></div><p class="gig-role">Bassist</p></li>
    </ul>
  </div>
</section>

<section class="py-24 border-t border-rule text-center">
  <div class="container-x">
    <h2 class="display text-4xl lg:text-5xl">Want Grant on <span class="italic text-gold">your stage</span>?</h2>
    <a href="/contact/" class="btn btn-gold mt-10">Check a date</a>
  </div>
</section>

</BaseLayout>
